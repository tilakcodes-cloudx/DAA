INF = 999

graph = [
    [0, 5, 10],
    [INF, 0, 3, INF],
    [6, INF, 0, 1],
    [INF, INF, INF, 0]
]

n = len(graph)

for k in range(n):
    for i in range(n):
        for j in range(n):
            graph[i][j] = min(graph[i][j], graph[i][k] + graph[k][j])

print("Shortest Distance Matrix:")
for row in graph:
    print(row)