import heapq

graph = {
    'A': [('B', 2), ('C', 3)],
    'B': [('A', 2), ('C', 1), ('D', 4)],
    'C': [('A', 3), ('B', 1), ('D', 5)],
    'D': [('B', 4), ('C', 5)]
}

visited = []
heap = [(0, 'A')]

while heap:
    w, node = heapq.heappop(heap)

    if node not in visited:
        visited.append(node)
        print((w, node))

        for n, wt in graph[node]:
            if n not in visited:
                heapq.heappush(heap, (wt, n))